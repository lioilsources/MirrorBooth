SPARK_BASE_URL=http://192.168.88.66:8000/v1
SPARK_MODEL=llama3
SPARK_API_KEY=dummy

# Auto-integration of generated shaders into the Flutter app.
# AUTO_INSTALL=true installs by default; --no-install overrides per run.
AUTO_INSTALL=true
# Minimum ranker overall score (0-10) required before a shader is installed.
MIN_INSTALL_SCORE=7.0
